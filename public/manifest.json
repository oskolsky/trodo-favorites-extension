{
  "manifest_version": 3,
  "name": "Trodo Favorites",
  "version": "1.0.0",
  "description": "Save Trodo products to favorites",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.trodo.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.trodo.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Trodo Favorites",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}